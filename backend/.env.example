# Database
DATABASE_URL=postgresql://localhost:5432/afripay_dev

# Stellar
STELLAR_NETWORK=testnet
STELLAR_HORIZON=https://horizon-testnet.stellar.org

# Redis (job queues)
REDIS_URL=redis://localhost:6379

# Mobile Money - MTN MoMo (Collections + Disbursements)
# Base URL / target environment for the MTN MoMo API. Defaults shown are for sandbox.
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_TARGET_ENVIRONMENT=sandbox
# Primary/Ocp-Apim-Subscription-Key from the MTN MoMo developer portal.
MTN_MOMO_API_KEY=
# API user + secret provisioned for the Collections product.
MTN_MOMO_COLLECTION_API_USER=
MTN_MOMO_COLLECTION_API_SECRET=
# API user + secret provisioned for the Disbursements product.
MTN_MOMO_DISBURSEMENT_API_USER=
MTN_MOMO_DISBURSEMENT_API_SECRET=
# Publicly reachable URL MTN will POST payment results to (X-Callback-Url).
MTN_MOMO_CALLBACK_URL=
# Shared secret appended as ?token= on the callback URL to authenticate inbound webhooks.
MTN_MOMO_WEBHOOK_TOKEN=

AIRTEL_MONEY_API_KEY=

# KYC
SMILE_IDENTITY_PARTNER_ID=
SMILE_IDENTITY_API_KEY=

# Exchange rates
OPEN_EXCHANGE_RATES_APP_ID=

# App
PORT=4000
